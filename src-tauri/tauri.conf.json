{
  "version": "0.0.2",
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "bundle": {
    "active": true,
    "longDescription": "RedClash - A Clash GUI based on clash-verge-rev",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": ["resources"],
    "publisher": "RedClash",
    "externalBin": ["sidecar/verge-mihomo", "sidecar/verge-mihomo-alpha"],
    "copyright": "Copyright (C) 2025 QiuYeDeng. GNU GPL v3.0.",
    "category": "DeveloperTool",
    "shortDescription": "RedClash",
    "createUpdaterArtifacts": true
  },
  "build": {
    "beforeBuildCommand": "pnpm run web:build",
    "frontendDist": "../dist",
    "beforeDevCommand": "pnpm run web:dev",
    "devUrl": "http://localhost:3000/",
    "removeUnusedCommands": true
  },
  "productName": "RedClash",
  "identifier": "io.github.QiuYeDeng.red-clash",
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["clash", "red-clash"]
      }
    }
  },
  "app": {
    "windows": [
      {
        "decorations": false,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "width": 1024,
        "height": 720,
        "minWidth": 800,
        "minHeight": 540,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "capabilities": ["desktop-capability", "migrated"],
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"],
          "requireLiteralLeadingDot": false
        }
      },
      "csp": null
    }
  }
}
